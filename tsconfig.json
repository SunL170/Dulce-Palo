{
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "dist"],

  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "moduleResolution": "Bundler",

    "strict": false,

    "skipLibCheck": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "resolveJsonModule": true,

    "types": ["vite/client"],

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "noEmit": true
  }
}